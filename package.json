{
  "name": "ecsia-monorepo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.2.2",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit false",
    "typecheck:extras": "tsc -p examples/tsconfig.json && tsc -p bench/tsconfig.json",
    "bench": "vitest bench --run",
    "bench:macro": "BENCH_MACRO=1 vitest run --project bench",
    "bench:macro:pool": "BENCH_MACRO=1 vitest run --project bench bench/test/heavy-pool.smoke.test.ts",
    "smoke:runtime": "node scripts/runtime-smoke.mjs",
    "smoke:browser:bundle": "node scripts/browser-smoke/build.mjs",
    "smoke:browser": "playwright test --config scripts/browser-smoke/playwright.config.ts"
  },
  "devDependencies": {
    "@playwright/test": "1.49.1",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "2.1.9",
    "bitecs": "^0.3.40",
    "esbuild": "0.21.5",
    "fast-check": "^3.23.0",
    "miniplex": "^2.0.0",
    "tinybench": "^3.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
