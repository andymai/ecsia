{
  "name": "ecsia-monorepo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.2.2",
  "type": "module",
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit false",
    "typecheck:extras": "tsc -p examples/tsconfig.json && tsc -p bench/tsconfig.json",
    "bench": "vitest bench --run",
    "bench:macro": "BENCH_MACRO=1 vitest run --project bench",
    "bench:macro:pool": "BENCH_MACRO=1 vitest run --project bench bench/test/heavy-pool.smoke.test.ts",
    "bench:report": "node scripts/bench-report.mjs",
    "smoke:runtime": "node scripts/runtime-smoke.mjs",
    "smoke:browser:bundle": "node scripts/browser-smoke/build.mjs",
    "smoke:browser": "playwright test --config scripts/browser-smoke/playwright.config.ts",
    "docs:api": "typedoc",
    "docs:check": "node scripts/check-doc-snippets.mjs",
    "docs:dev": "vitepress dev website",
    "docs:build": "pnpm docs:api && vitepress build website && pnpm docs:check"
  },
  "devDependencies": {
    "ecsia": "workspace:*",
    "@ecsia/scheduler": "workspace:*",
    "@ecsia/schema": "workspace:*",
    "@playwright/test": "1.60.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.169.0",
    "@vitest/coverage-v8": "4.1.8",
    "bitecs": "^0.3.40",
    "esbuild": "0.28.0",
    "fast-check": "^3.23.0",
    "jsdom": "^26.0.0",
    "miniplex": "^2.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.169.0",
    "tinybench": "^3.0.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^5.7.0",
    "vitepress": "2.0.0-alpha.17",
    "vitest": "4.1.8"
  }
}
