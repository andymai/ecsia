{
  "name": "ecsia",
  "version": "0.1.0",
  "description": "Batteries-included, TypeScript-native Entity Component System: archetype/SoA storage, typed accessors, first-class relations, and auto-parallel worker execution that is bit-identical to the serial path. The umbrella package re-exporting the full cohesive public surface.",
  "keywords": [
    "ecs",
    "entity-component-system",
    "gamedev",
    "game-engine",
    "archetype",
    "soa",
    "data-oriented",
    "simulation",
    "typescript",
    "parallel",
    "worker-threads",
    "relations"
  ],
  "license": "MIT",
  "author": "Andy Aragon",
  "homepage": "https://github.com/andymai/ecsia",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andymai/ecsia.git",
    "directory": "packages/ecsia"
  },
  "bugs": {
    "url": "https://github.com/andymai/ecsia/issues"
  },
  "engines": {
    "node": ">=22.13"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": { "build": "tsc -b" },
  "dependencies": {
    "@ecsia/core": "workspace:*",
    "@ecsia/schema": "workspace:*",
    "@ecsia/relations": "workspace:*",
    "@ecsia/scheduler": "workspace:*",
    "@ecsia/serialization": "workspace:*"
  }
}
