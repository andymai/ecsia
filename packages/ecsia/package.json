{
  "name": "@ecsia/kit",
  "version": "0.18.1",
  "description": "Fast, type-safe entity component system for TypeScript with automatic multithreading.",
  "keywords": [
    "ecs",
    "entity-component-system",
    "gamedev",
    "game-engine",
    "archetype",
    "soa",
    "data-oriented",
    "simulation",
    "typescript",
    "parallel",
    "worker-threads",
    "relations"
  ],
  "license": "MIT",
  "author": "Andy Aragon",
  "homepage": "https://github.com/andymai/ecsia",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andymai/ecsia.git",
    "directory": "packages/ecsia"
  },
  "bugs": {
    "url": "https://github.com/andymai/ecsia/issues"
  },
  "engines": {
    "node": ">=22.13"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b"
  },
  "dependencies": {
    "@ecsia/core": "workspace:*",
    "@ecsia/schema": "workspace:*",
    "@ecsia/relations": "workspace:*",
    "@ecsia/scheduler": "workspace:*",
    "@ecsia/serialization": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
