{
  "name": "@ecsia/devtools",
  "version": "0.1.0",
  "description": "Inspection and HTML-report devtools for the ecsia ECS. Deliberately NOT re-exported from the umbrella and imported by nothing in the framework, so it never ships in a consumer bundle unless explicitly pulled in.",
  "keywords": [
    "ecs",
    "entity-component-system",
    "ecsia",
    "devtools",
    "inspector",
    "debugging",
    "data-oriented",
    "typescript"
  ],
  "license": "MIT",
  "author": "Andy Aragon",
  "homepage": "https://github.com/andymai/ecsia",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andymai/ecsia.git",
    "directory": "packages/devtools"
  },
  "bugs": {
    "url": "https://github.com/andymai/ecsia/issues"
  },
  "engines": {
    "node": ">=22.13"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "publishConfig": { "access": "public" },
  "scripts": { "build": "tsc -b" },
  "dependencies": {
    "@ecsia/core": "workspace:*",
    "@ecsia/schema": "workspace:*",
    "@ecsia/scheduler": "workspace:*"
  }
}
