{
  "name": "@ecsia/serialization",
  "version": "0.24.0",
  "description": "Save and load ecsia worlds: full snapshots, incremental deltas, and worker handoff.",
  "keywords": [
    "ecs",
    "entity-component-system",
    "ecsia",
    "serialization",
    "snapshot",
    "delta",
    "networking",
    "data-oriented",
    "typescript"
  ],
  "license": "MIT",
  "author": "Andy Aragon",
  "homepage": "https://github.com/andymai/ecsia",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andymai/ecsia.git",
    "directory": "packages/serialization"
  },
  "bugs": {
    "url": "https://github.com/andymai/ecsia/issues"
  },
  "engines": {
    "node": ">=22.13"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b"
  },
  "dependencies": {
    "@ecsia/core": "workspace:*",
    "@ecsia/schema": "workspace:*"
  },
  "devDependencies": {
    "@ecsia/relations": "workspace:*"
  }
}
